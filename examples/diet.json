{
  "name": "Basic diet problem",
  "description": "Diet instance from the document",
  "parameters": [
    {
      "name": "Number of foods",
      "symbol": "N",
      "value": 5
    },
    {
      "name": "Maximum volume",
      "symbol": "Vmax",
      "value": 40
    }
  ],
  "variables": [
    {
      "name": "Number of servings",
      "symbol": "x",
      "within": "integers",
      "range": {
        "lowerBound": 0,
        "upperBound": "Infinity"
      },
      "shape": {
        "type": "vector",
        "isPermutation": false,
        "size": {
          "fixed": false,
          "value": "N"
        }
      }
    }
  ],
  "goals": [
    {
      "name": "Minimize cost of servings",
      "sense": "minimize",
      "expression": "sum x[i]*food[i].cost over i=(1:N)"
    }
  ],
  "constraints": [
    {
      "name": "Limit the volume of food consumed",
      "expression": "sum x[i]*food[i].volume over i=(1:N) <= Vmax"
    },
    {
      "name": "Limit nutrient consumption of calories",
      "expression": "nutrientsLimit[1].minimum <= sum x[i]*food[i].cal over i=(1:N) <= nutrientsLimit[1].maximum"
    },
    {
      "name": "Limit nutrient consumption of carbohydrates",
      "expression": "nutrientsLimit[2].minimum <= sum x[i]*food[i].carbo over i=(1:N) <= nutrientsLimit[2].maximum"
    },
    {
      "name": "Limit nutrient consumption of proteins",
      "expression": "nutrientsLimit[3].minimum <= sum x[i]*food[i].proteins over i=(1:N) <= nutrientsLimit[3].maximum"
    },
    {
      "name": "Limit nutrient consumption of iron",
      "expression": "nutrientsLimit[4].minimum <= sum x[i]*food[i].iron over i=(1:N) <= nutrientsLimit[4].maximum"
    }
  ],
  "classes": [
    {
      "name": "Food",
      "symbol": "food",
      "attributes": [
        { "name": "Name", "symbol": "name" },
        { "name": "Cost", "symbol": "cost" },
        { "name": "Volume", "symbol": "volume" },
        { "name": "Calories", "symbol": "cal" },
        { "name": "Carbohydrates", "symbol": "carbo" },
        { "name": "Proteins", "symbol": "proteins" },
        { "name": "Iron", "symbol": "iron" }
      ]
    },
    {
      "name": "NutrientsLimit",
      "symbol": "nutrientsLimit",
      "attributes": [
        { "name": "Name", "symbol": "name" },
        { "name": "Minimum", "symbol": "minimum" },
        { "name": "Maximum", "symbol": "maximum" }
      ]
    }
  ],
